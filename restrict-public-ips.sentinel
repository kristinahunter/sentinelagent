# restrict-public-ips.sentinel
#
# Purpose: Block Compute Engine instances from having external (public) IP
# addresses unless they carry the "allow-public-ip" label explicitly set to
# "true". Bastion and load-balancer hosts are common exceptions; all others
# should route egress through Cloud NAT.
#
# Enforcement: hard-mandatory

import "tfplan/v2" as tfplan

# ── Helpers ───────────────────────────────────────────────────────────────────

all_compute_instances = filter tfplan.resource_changes as _, rc {
  rc.type is "google_compute_instance" and
  (rc.change.actions contains "create" or rc.change.actions contains "update")
}

# Returns true if the instance has at least one network interface with an
# access_config block (i.e. an ephemeral or static external IP assigned).
has_public_ip = func(rc) {
  interfaces = rc.change.after.network_interface else []
  return any interfaces as _, iface {
    length(iface.access_config else []) > 0
  }
}

# Returns true if the resource carries the explicit opt-in label.
has_public_ip_label = func(rc) {
  labels = rc.change.after.labels else {}
  return labels["allow-public-ip"] else "" is "true"
}

# Violation: has a public IP but did NOT opt in via label.
violations = filter all_compute_instances as address, rc {
  has_public_ip(rc) and not has_public_ip_label(rc)
}

# ── Messages ──────────────────────────────────────────────────────────────────

msgs = map violations as address, _ {
  address + " has a public IP but is missing the label " +
  "\"allow-public-ip = true\". Add the label to opt in, or remove the " +
  "access_config block and route egress through Cloud NAT."
}

# ── Main rule ─────────────────────────────────────────────────────────────────

main = rule {
  length(violations) is 0
}
