# restrict-machine-types.sentinel
#
# Purpose: Only permit an approved list of GCP machine types for Compute Engine
# instances. Prevents use of expensive or non-standard machine families.
#
# Enforcement: hard-mandatory

import "tfplan/v2" as tfplan

# ── Approved machine types ────────────────────────────────────────────────────

allowed_machine_types = [
  "e2-micro",
  "e2-small",
  "e2-medium",
  "e2-standard-2",
  "e2-standard-4",
  "e2-standard-8",
  "n1-standard-1",
  "n1-standard-2",
  "n1-standard-4",
]

# ── Helpers ───────────────────────────────────────────────────────────────────

# All compute instance resource changes that are creates or updates
all_compute_instances = filter tfplan.resource_changes as _, rc {
  rc.type is "google_compute_instance" and
  (rc.change.actions contains "create" or rc.change.actions contains "update")
}

# Instances whose machine_type is not in the approved list
violations = filter all_compute_instances as address, rc {
  rc.change.after.machine_type not in allowed_machine_types
}

# ── Messages ──────────────────────────────────────────────────────────────────

msgs = map violations as address, rc {
  address + " uses disallowed machine type \"" + rc.change.after.machine_type +
  "\". Allowed types: " + allowed_machine_types
}

# ── Main rule ─────────────────────────────────────────────────────────────────

main = rule {
  length(violations) is 0
}
